ACTION=="add", SUBSYSTEM=="usb", ATTR{idVendor}=="05ac", ATTR{idProduct}=="8302", ATTR{bConfigurationValue}=="1", ATTR{bConfigurationValue}="0", ATTR{bConfigurationValue}="2"

SUBSYSTEM=="input", ATTR{name}=="Apple Inc. Touch Bar Display Touchpad", GROUP="input", MODE="0660", TAG+="systemd", ENV{SYSTEMD_WANTS}="tiny-dfr.service"
SUBSYSTEM=="input", ATTR{name}=="MacBookPro17,1 Touch Bar", GROUP="input", MODE="0660", TAG+="systemd", ENV{SYSTEMD_WANTS}="tiny-dfr.service"
SUBSYSTEM=="input", ATTR{name}=="Mac14,7 Touch Bar", GROUP="input", MODE="0660", TAG+="systemd", ENV{SYSTEMD_WANTS}="tiny-dfr.service"

SUBSYSTEM=="drm", KERNEL=="card[0-9]*", DRIVERS=="adp|appletbdrm", GROUP="video", MODE="0660", TAG+="systemd", ENV{SYSTEMD_ALIAS}="/dev/tiny_dfr_display"

SUBSYSTEM=="backlight", KERNEL=="appletb_backlight", DRIVERS=="hid-appletb-bl", GROUP="video", MODE="0664", TAG+="systemd", ENV{SYSTEMD_ALIAS}="/dev/tiny_dfr_backlight"
SUBSYSTEM=="backlight", KERNEL=="228200000.display-pipe.0", DRIVERS=="panel-summit", GROUP="video", MODE="0664", TAG+="systemd", ENV{SYSTEMD_ALIAS}="/dev/tiny_dfr_backlight"
SUBSYSTEM=="backlight", KERNELS=="228600000.dsi.0", DRIVERS=="panel-summit", GROUP="video", MODE="0664", TAG+="systemd", ENV{SYSTEMD_ALIAS}="/dev/tiny_dfr_backlight"

SUBSYSTEM=="backlight", KERNEL=="apple-panel-bl", GROUP="video", MODE="0664", TAG+="systemd", ENV{SYSTEMD_ALIAS}="/dev/tiny_dfr_display_backlight"
SUBSYSTEM=="backlight", KERNEL=="gmux_backlight", GROUP="video", MODE="0664", TAG+="systemd", ENV{SYSTEMD_ALIAS}="/dev/tiny_dfr_display_backlight"
SUBSYSTEM=="backlight", KERNEL=="intel_backlight", GROUP="video", MODE="0664", TAG+="systemd", ENV{SYSTEMD_ALIAS}="/dev/tiny_dfr_display_backlight"
SUBSYSTEM=="backlight", KERNEL=="acpi_video0", GROUP="video", MODE="0664", TAG+="systemd", ENV{SYSTEMD_ALIAS}="/dev/tiny_dfr_display_backlight"
